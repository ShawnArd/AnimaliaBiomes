<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:padding="24dp"
    android:background="@color/background">

    <TextView
        android:id="@+id/tvBiomeName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="@color/ocean_deep"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Choose a Puzzle"
        android:textSize="14sp"
        android:textColor="@color/text_secondary"
        android:layout_marginBottom="32dp"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnPuzzle1"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:textSize="16sp"
        android:backgroundTint="@color/ocean_deep"
        android:layout_marginBottom="12dp"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnPuzzle2"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:textSize="16sp"
        android:backgroundTint="@color/ocean_mid"
        android:layout_marginBottom="12dp"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnPuzzle3"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:textSize="16sp"
        android:backgroundTint="@color/ocean_light"
        android:layout_marginBottom="12dp"/>

</LinearLayout>
