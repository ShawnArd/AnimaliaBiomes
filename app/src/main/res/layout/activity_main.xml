<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:background="@color/ocean_deep">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Animalia Biomes"
        android:textSize="30sp"
        android:textStyle="bold"
        android:textColor="@color/white"
        android:letterSpacing="0.05"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Nonogram"
        android:textSize="16sp"
        android:textColor="@color/ocean_light"
        android:letterSpacing="0.15"
        android:layout_marginBottom="48dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Select a Biome"
        android:textSize="14sp"
        android:textColor="@color/ocean_foam"
        android:layout_marginBottom="16dp"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnOceanBiome"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:text="🌊  Ocean"
        android:textSize="18sp"
        android:backgroundTint="@color/ocean_mid"
        android:textColor="@color/white"/>

</LinearLayout>
