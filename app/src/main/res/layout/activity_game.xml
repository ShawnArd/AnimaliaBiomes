<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_ocean">

    <!-- Top bar: back button + puzzle name + strikes -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="8dp"
        android:background="#881A237E">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Back"
            android:layout_marginEnd="4dp"/>

        <TextView
            android:id="@+id/tvPuzzleName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/white"/>

        <ImageView
            android:id="@+id/ivStrike1"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/ic_strike"
            android:alpha="0.2"
            android:layout_marginStart="6dp"/>

        <ImageView
            android:id="@+id/ivStrike2"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/ic_strike"
            android:alpha="0.2"
            android:layout_marginStart="6dp"/>

        <ImageView
            android:id="@+id/ivStrike3"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/ic_strike"
            android:alpha="0.2"
            android:layout_marginStart="6dp"/>

    </LinearLayout>

    <!-- Picross grid (fills remaining space) -->
    <com.nonogram.animaliabiomes.ui.game.PicrossGridView
        android:id="@+id/picrossGridView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="12dp"
        android:background="@android:color/transparent"/>

</LinearLayout>
